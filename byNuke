end

function ESPObject:_drawCorner(boxX, boxY, boxW, boxH)
    local cornerW = boxW * 0.25
    local cornerH = boxH * 0.25
    local points = {
        {Vector2.new(boxX, boxY), Vector2.new(boxX + cornerW, boxY)},
        {Vector2.new(boxX, boxY), Vector2.new(boxX, boxY + cornerH)},
        {Vector2.new(boxX + boxW, boxY), Vector2.new(boxX + boxW - cornerW, boxY)},
        {Vector2.new(boxX + boxW, boxY), Vector2.new(boxX + boxW, boxY + cornerH)},
        {Vector2.new(boxX, boxY + boxH), Vector2.new(boxX + cornerW, boxY + boxH)},
        {Vector2.new(boxX, boxY + boxH), Vector2.new(boxX, boxY + boxH - cornerH)},
        {Vector2.new(boxX + boxW, boxY + boxH), Vector2.new(boxX + boxW - cornerW, boxY + boxH)},
        {Vector2.new(boxX + boxW, boxY + boxH), Vector2.new(boxX + boxW, boxY + boxH - cornerH)},
    }

    for i = 1, 8 do
        if self._settings.BoxOutlineEnabled then
            self._drawings.cornerOutlines[i].From = points[i][1]
            self._drawings.cornerOutlines[i].To = points[i][2]
            self._drawings.cornerOutlines[i].Color = self._settings.BoxOutlineColor
            self._drawings.cornerOutlines[i].Thickness = self._settings.BoxThickness + self._settings.OutlineThickness
            self._drawings.cornerOutlines[i].Visible = true
        end

        self._drawings.cornerLines[i].From = points[i][1]
        self._drawings.cornerLines[i].To = points[i][2]
        self._drawings.cornerLines[i].Color = self._settings.BoxColor
        self._drawings.cornerLines[i].Thickness = self._settings.BoxThickness
        self._drawings.cornerLines[i].Visible = true
    end
end

function ESPObject:_drawRounded(boxX, boxY, boxW, boxH)
    local radius = math.min(boxW, boxH) * 0.15
    local segmentsPerCorner = 5
    local index = 1
    local corners = {
        {cx = boxX + radius, cy = boxY + radius, sa = math.pi, ea = math.pi * 1.5},
        {cx = boxX + boxW - radius, cy = boxY + radius, sa = math.pi * 1.5, ea = math.pi * 2},
        {cx = boxX + boxW - radius, cy = boxY + boxH - radius, sa = 0, ea = math.pi * 0.5},
        {cx = boxX + radius, cy = boxY + boxH - radius, sa = math.pi * 0.5, ea = math.pi},
    }

    for _, corner in ipairs(corners) do
        for segment = 0, segmentsPerCorner - 1 do
            local angle1 = corner.sa + (corner.ea - corner.sa) * (segment / segmentsPerCorner)
            local angle2 = corner.sa + (corner.ea - corner.sa) * ((segment + 1) / segmentsPerCorner)
            local from = Vector2.new(corner.cx + math.cos(angle1) * radius, corner.cy + math.sin(angle1) * radius)
            local to = Vector2.new(corner.cx + math.cos(angle2) * radius, corner.cy + math.sin(angle2) * radius)

            if index <= #self._drawings.roundedLines then
                if self._settings.BoxOutlineEnabled then
                    self._drawings.roundedOutlines[index].From = from
                    self._drawings.roundedOutlines[index].To = to
                    self._drawings.roundedOutlines[index].Color = self._settings.BoxOutlineColor
                    self._drawings.roundedOutlines[index].Thickness = self._settings.BoxThickness + self._settings.OutlineThickness
                    self._drawings.roundedOutlines[index].Visible = true
                end

                self._drawings.roundedLines[index].From = from
                self._drawings.roundedLines[index].To = to
                self._drawings.roundedLines[index].Color = self._settings.BoxColor
                self._drawings.roundedLines[index].Thickness = self._settings.BoxThickness
                self._drawings.roundedLines[index].Visible = true
                index = index + 1
            end
        end
    end

    local sides = {
        {Vector2.new(boxX + radius, boxY), Vector2.new(boxX + boxW - radius, boxY)},
        {Vector2.new(boxX + boxW, boxY + radius), Vector2.new(boxX + boxW, boxY + boxH - radius)},
        {Vector2.new(boxX + boxW - radius, boxY + boxH), Vector2.new(boxX + radius, boxY + boxH)},
        {Vector2.new(boxX, boxY + boxH - radius), Vector2.new(boxX, boxY + radius)},
    }

    for _, side in ipairs(sides) do
        if index <= #self._drawings.roundedLines then
            if self._settings.BoxOutlineEnabled then
                self._drawings.roundedOutlines[index].From = side[1]
                self._drawings.roundedOutlines[index].To = side[2]
                self._drawings.roundedOutlines[index].Color = self._settings.BoxOutlineColor
                self._drawings.roundedOutlines[index].Thickness = self._settings.BoxThickness + self._settings.OutlineThickness
                self._drawings.roundedOutlines[index].Visible = true
            end

            self._drawings.roundedLines[index].From = side[1]
            self._drawings.roundedLines[index].To = side[2]
            self._drawings.roundedLines[index].Color = self._settings.BoxColor
            self._drawings.roundedLines[index].Thickness = self._settings.BoxThickness
            self._drawings.roundedLines[index].Visible = true
            index = index + 1
        end
    end

    for i = index, #self._drawings.roundedLines do
        self._drawings.roundedLines[i].Visible = false
        if i <= #self._drawings.roundedOutlines then
            self._drawings.roundedOutlines[i].Visible = false
        end
    end
end

function ESPObject:_drawDashed(boxX, boxY, boxW, boxH)
    local segments = 10
    local gap = 0.4
    local index = 1
    local sides = {
        {Vector2.new(boxX, boxY), Vector2.new(boxX + boxW, boxY)},
        {Vector2.new(boxX + boxW, boxY), Vector2.new(boxX + boxW, boxY + boxH)},
        {Vector2.new(boxX + boxW, boxY + boxH), Vector2.new(boxX, boxY + boxH)},
        {Vector2.new(boxX, boxY + boxH), Vector2.new(boxX, boxY)},
    }

    for _, side in ipairs(sides) do
        local diff = side[2] - side[1]
        for segment = 0, segments - 1 do
            local t0 = segment / segments
            local t1 = math.min((segment + 1 - gap) / segments, 1)
            local from = side[1] + diff * t0
            local to = side[1] + diff * t1

            if index <= #self._drawings.dashedLines then
                if self._settings.BoxOutlineEnabled then
                    self._drawings.dashedOutlines[index].From = from
                    self._drawings.dashedOutlines[index].To = to
                    self._drawings.dashedOutlines[index].Color = self._settings.BoxOutlineColor
                    self._drawings.dashedOutlines[index].Thickness = self._settings.BoxThickness + self._settings.OutlineThickness
                    self._drawings.dashedOutlines[index].Visible = true
                end

                self._drawings.dashedLines[index].From = from
                self._drawings.dashedLines[index].To = to
                self._drawings.dashedLines[index].Color = self._settings.BoxColor
                self._drawings.dashedLines[index].Thickness = self._settings.BoxThickness
                self._drawings.dashedLines[index].Visible = true
                index = index + 1
            end
        end
    end

    for i = index, #self._drawings.dashedLines do
        self._drawings.dashedLines[i].Visible = false
        if i <= #self._drawings.dashedOutlines then
            self._drawings.dashedOutlines[i].Visible = false
        end
    end
end

function ESPObject:_draw3DBox(character, camera)
    local success, boxCFrame, boxSize = pcall(function()
        return character:GetBoundingBox()
    end)
    if not success or not boxCFrame or not boxSize then
        return
    end

    local half = boxSize / 2
    local corners = {
        Vector3.new(-half.X, -half.Y, -half.Z),
        Vector3.new(half.X, -half.Y, -half.Z),
        Vector3.new(half.X, half.Y, -half.Z),
        Vector3.new(-half.X, half.Y, -half.Z),
        Vector3.new(-half.X, -half.Y, half.Z),
        Vector3.new(half.X, -half.Y, half.Z),
        Vector3.new(half.X, half.Y, half.Z),
        Vector3.new(-half.X, half.Y, half.Z),
    }
    local edges = {
        {1, 2}, {2, 3}, {3, 4}, {4, 1},
        {5, 6}, {6, 7}, {7, 8}, {8, 5},
        {1, 5}, {2, 6}, {3, 7}, {4, 8},
    }
    local points = {}

    for index, offset in ipairs(corners) do
        local screen, visible = camera:WorldToViewportPoint((boxCFrame * CFrame.new(offset)).Position)
        if not visible or screen.Z <= 0 then
            for _, line in ipairs(self._drawings.box3DOutlines) do line.Visible = false end
            for _, line in ipairs(self._drawings.box3DLines) do line.Visible = false end
            return
        end
        points[index] = Vector2.new(screen.X, screen.Y)
    end

    for index, edge in ipairs(edges) do
        if self._settings.BoxOutlineEnabled then
            self._drawings.box3DOutlines[index].From = points[edge[1]]
            self._drawings.box3DOutlines[index].To = points[edge[2]]
            self._drawings.box3DOutlines[index].Color = self._settings.BoxOutlineColor
            self._drawings.box3DOutlines[index].Thickness = self._settings.BoxThickness + self._settings.OutlineThickness
            self._drawings.box3DOutlines[index].Visible = true
        end

        self._drawings.box3DLines[index].From = points[edge[1]]
        self._drawings.box3DLines[index].To = points[edge[2]]
        self._drawings.box3DLines[index].Color = self._settings.BoxColor
        self._drawings.box3DLines[index].Thickness = self._settings.BoxThickness
        self._drawings.box3DLines[index].Visible = true
    end
end

function ESPObject:_updateSkeleton(character, camera)
    local r6Map = {
        Head = "Head",
        UpperTorso = "Torso",
        LowerTorso = "Torso",
        LeftUpperArm = "Left Arm",
        LeftLowerArm = "Left Arm",
        LeftHand = "Left Arm",
        RightUpperArm = "Right Arm",
        RightLowerArm = "Right Arm",
        RightHand = "Right Arm",
        LeftUpperLeg = "Left Leg",
        LeftLowerLeg = "Left Leg",
        LeftFoot = "Left Leg",
        RightUpperLeg = "Right Leg",
        RightLowerLeg = "Right Leg",
        RightFoot = "Right Leg",
    }

    local nodes = {
        "Head", "UpperTorso", "LowerTorso",
        "LeftUpperArm", "LeftLowerArm", "LeftHand",
        "RightUpperArm", "RightLowerArm", "RightHand",
        "LeftUpperLeg", "LeftLowerLeg", "LeftFoot",
        "RightUpperLeg", "RightLowerLeg", "RightFoot",
    }

    local positions = {}
    local valid = true

    for _, name in ipairs(nodes) do
        local part = character:FindFirstChild(name) or character:FindFirstChild(r6Map[name] or "")
        if not part then
            valid = false
            break
        end

        local screenPos, visible = camera:WorldToViewportPoint(part.Position)
        if not visible then
            valid = false
            break
        end

        positions[name] = Vector2.new(screenPos.X, screenPos.Y)
    end

    if not valid then
        for _, line in ipairs(self._skeletonOutlineLines) do
            line.Visible = false
        end
        for _, line in ipairs(self._skeletonLines) do
            line.Visible = false
        end
        return
    end

    for index, bone in ipairs(self._boneConnections) do
        local from = positions[bone[1]]
        local to = positions[bone[2]]

        if from and to then
            self._skeletonOutlineLines[index].From = from
            self._skeletonOutlineLines[index].To = to
            self._skeletonOutlineLines[index].Color = self._settings.SkeletonOutlineColor
            self._skeletonOutlineLines[index].Thickness = self._settings.SkeletonThickness + self._settings.OutlineThickness
            self._skeletonOutlineLines[index].Visible = self._settings.SkeletonOutlineEnabled

            self._skeletonLines[index].From = from
            self._skeletonLines[index].To = to
            self._skeletonLines[index].Color = self._settings.SkeletonColor
            self._skeletonLines[index].Thickness = self._settings.SkeletonThickness
            self._skeletonLines[index].Visible = true
        else
            self._skeletonOutlineLines[index].Visible = false
            self._skeletonLines[index].Visible = false
        end
    end
end

function ESPObject:update(camera, localPlayer, isTeammate)
    if isTeammate then
        self:hide()
        return
    end

    local character = self._player.Character
    if not character then
        self:hide()
        return
    end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart")
    local head = character:FindFirstChild("Head")
    if not humanoid or not root or not head or humanoid.Health <= 0 then
        self:hide()
        return
    end

    local localCharacter = localPlayer.Character
    local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
    if not localRoot then
        self:hide()
        return
    end

    local rootScreen, onScreen = camera:WorldToViewportPoint(root.Position)
    if not onScreen then
        self:hide()
        return
    end

    local now = tick()
    local delta = math.clamp(now - self._lastFadeUpdate, 0, 0.1)
    self._lastFadeUpdate = now
    self._isVisibleOnScreen = true

    local headScreen = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
    local footScreen = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
    local boxH = math.abs(headScreen.Y - footScreen.Y)
    local boxW = boxH * 0.6
    local boxX = rootScreen.X - boxW / 2
    local boxY = headScreen.Y
    local distance = (root.Position - localRoot.Position).Magnitude

    self:_hideAllBox()

    if self._settings.ProfileEnabled then
        self:_updateProfile(Vector2.new(rootScreen.X, boxY), boxY - 18)
        self:_setFeatureAlpha("Profile", self:_stepFeatureFade("Profile", delta))
    else
        self:_hideProfile()
    end

    if self._settings.BoxEnabled then
        local boxType = self._settings.BoxType
        if boxType == "Standard" then
            self:_drawStandard(boxX, boxY, boxW, boxH)
        elseif boxType == "Corner" then
            self:_drawCorner(boxX, boxY, boxW, boxH)
        elseif boxType == "Rounded" then
            self:_drawRounded(boxX, boxY, boxW, boxH)
        elseif boxType == "Dashed" then
            self:_drawDashed(boxX, boxY, boxW, boxH)
        elseif boxType == "3D" then
            self:_draw3DBox(character, camera)
        end
        self:_setFeatureAlpha("Box", self:_stepFeatureFade("Box", delta))
    end

    if self._settings.NameEnabled then
        self._drawings.nameLabel.Text = self._player.DisplayName
        self._drawings.nameLabel.Position = Vector2.new(rootScreen.X, boxY - 16)
        self._drawings.nameLabel.Color = self._settings.NameColor
        self._drawings.nameLabel.Outline = self._settings.NameOutlineEnabled
        pcall(function()
            self._drawings.nameLabel.OutlineColor = self._settings.NameOutlineColor
        end)
        self._drawings.nameLabel.Visible = true
        self:_setFeatureAlpha("Name", self:_stepFeatureFade("Name", delta))
    else
        self._drawings.nameLabel.Visible = false
    end

    if self._settings.DistanceEnabled then
        self._drawings.distLabel.Text = string.format("[%dm]", math.floor(distance))
        self._drawings.distLabel.Position = Vector2.new(rootScreen.X, footScreen.Y + 2)
        self._drawings.distLabel.Color = self._settings.DistanceColor
        self._drawings.distLabel.Outline = self._settings.DistanceOutlineEnabled
        pcall(function()
            self._drawings.distLabel.OutlineColor = self._settings.DistanceOutlineColor
        end)
        self._drawings.distLabel.Visible = true
        self:_setFeatureAlpha("Distance", self:_stepFeatureFade("Distance", delta))
    else
        self._drawings.distLabel.Visible = false
    end

    if self._settings.HealthBarEnabled then
        local healthFactor = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
        local healthLerp = math.clamp(delta * 8, 0, 1)
        self._healthProgress = self._healthProgress + (healthFactor - self._healthProgress) * healthLerp
        local displayedHealth = math.clamp(self._healthProgress, 0, 1)
        local barWidth = 3
        local barX = boxX - barWidth - 4

        self._drawings.healthBarBgOutline.Position = Vector2.new(barX - 1, boxY - 1)
        self._drawings.healthBarBgOutline.Size = Vector2.new(barWidth + 2, boxH + 2)
        self._drawings.healthBarBgOutline.Color = self._settings.HealthOutlineColor
        self._drawings.healthBarBgOutline.Visible = self._settings.HealthOutlineEnabled

        self._drawings.healthBarBg.Position = Vector2.new(barX, boxY)
        self._drawings.healthBarBg.Size = Vector2.new(barWidth, boxH)
        self._drawings.healthBarBg.Visible = true

        local fillHeight = boxH * displayedHealth
        self._drawings.healthBarFill.Position = Vector2.new(barX, boxY + boxH - fillHeight)
        self._drawings.healthBarFill.Size = Vector2.new(barWidth, fillHeight)
        self._drawings.healthBarFill.Color = Color3.fromRGB(math.floor((1 - displayedHealth) * 255), math.floor(displayedHealth * 255), 0)
        self._drawings.healthBarFill.Visible = true
        self:_setFeatureAlpha("Health", self:_stepFeatureFade("Health", delta))
    else
        self._drawings.healthBarBgOutline.Visible = false
        self._drawings.healthBarBg.Visible = false
        self._drawings.healthBarFill.Visible = false
    end

    if self._settings.SnaplineEnabled then
        local viewport = camera.ViewportSize
        local fromX, fromY
        local mode = self._settings.SnaplineMode
        if mode == "Bottom" then
            fromX, fromY = viewport.X / 2, viewport.Y
        elseif mode == "Top" then
            fromX, fromY = viewport.X / 2, 0
        elseif mode == "Center" then
            fromX, fromY = viewport.X / 2, viewport.Y / 2
        elseif mode == "Mouse" then
            local mousePosition = UserInputService:GetMouseLocation()
            fromX, fromY = mousePosition.X, mousePosition.Y
        else
            fromX, fromY = viewport.X / 2, viewport.Y
        end

        local snapFrom = Vector2.new(fromX, fromY)
        local snapTo = Vector2.new(rootScreen.X, footScreen.Y)
        self._drawings.snaplineOutline.From = snapFrom
        self._drawings.snaplineOutline.To = snapTo
        self._drawings.snaplineOutline.Color = self._settings.SnaplineOutlineColor
        self._drawings.snaplineOutline.Thickness = self._settings.SnaplineThickness + self._settings.OutlineThickness
        self._drawings.snaplineOutline.Visible = self._settings.SnaplineOutlineEnabled

        self._drawings.snapline.From = snapFrom
        self._drawings.snapline.To = snapTo
        self._drawings.snapline.Color = self._settings.SnaplineColor
        self._drawings.snapline.Thickness = self._settings.SnaplineThickness
        self._drawings.snapline.Visible = true
        self:_setFeatureAlpha("Snapline", self:_stepFeatureFade("Snapline", delta))
    else
        self._drawings.snaplineOutline.Visible = false
        self._drawings.snapline.Visible = false
    end

    if self._settings.SkeletonEnabled then
        self:_updateSkeleton(character, camera)
        self:_setFeatureAlpha("Skeleton", self:_stepFeatureFade("Skeleton", delta))
    else
        for _, line in ipairs(self._skeletonOutlineLines) do
            line.Visible = false
        end
        for _, line in ipairs(self._skeletonLines) do
            line.Visible = false
        end
    end

    if self._settings.HeadDotEnabled then
        self:_updateHeadDot(head, camera)
        self:_setFeatureAlpha("HeadDot", self:_stepFeatureFade("HeadDot", delta))
    else
        self._drawings.headDotOutline.Visible = false
        self._drawings.headDot.Visible = false
    end

    if self._settings.LookDirectionEnabled then
        self:_updateLookDirection(head, camera)
        self:_setFeatureAlpha("LookDirection", self:_stepFeatureFade("LookDirection", delta))
    else
        self._drawings.lookDirectionOutline.Visible = false
        self._drawings.lookDirection.Visible = false
        for _, line in ipairs(self._drawings.lookDirectionArrowOutlines) do line.Visible = false end
        for _, line in ipairs(self._drawings.lookDirectionArrows) do line.Visible = false end
    end

    if self._settings.HighlightEnabled then
        local highlightAlpha = self:_stepFeatureFade("Highlight", delta)
        if not self._highlight or not self._highlight.Parent then
            self._highlight = Instance.new("Highlight")
            self._highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            self._highlight.Parent = character
        end

        self._highlight.Adornee = character
        self._highlight.FillColor = self._settings.HighlightFillColor
        self._highlight.OutlineColor = self._settings.HighlightOutlineColor
        self._highlight.FillTransparency = 1 - ((1 - self._settings.HighlightFillTransparency) * highlightAlpha)
        self._highlight.OutlineTransparency = 1 - ((1 - self._settings.HighlightOutlineTransparency) * highlightAlpha)
        self._highlight.Enabled = true
    elseif self._highlight then
        self._highlight.Enabled = false
    end
end

function ESPObject:hide()
    self._isVisibleOnScreen = false
    self._lastFadeUpdate = tick()
    self._drawings.box.Visible = false
    self._drawings.boxOutline.Visible = false
    self._drawings.nameLabel.Visible = false
    self._drawings.distLabel.Visible = false
    self._drawings.healthBarBgOutline.Visible = false
    self._drawings.healthBarBg.Visible = false
        self._drawings.healthBarFill.Visible = false
    self._drawings.snaplineOutline.Visible = false
    self._drawings.snapline.Visible = false
    self._drawings.headDotOutline.Visible = false
    self._drawings.headDot.Visible = false
    self._drawings.lookDirectionOutline.Visible = false
    self._drawings.lookDirection.Visible = false
    self:_hideProfile()
    for _, line in ipairs(self._drawings.lookDirectionArrowOutlines) do line.Visible = false end
    for _, line in ipairs(self._drawings.lookDirectionArrows) do line.Visible = false end
    for _, line in ipairs(self._drawings.cornerOutlines) do line.Visible = false end
    for _, line in ipairs(self._drawings.cornerLines) do line.Visible = false end
    for _, line in ipairs(self._drawings.roundedOutlines) do line.Visible = false end
    for _, line in ipairs(self._drawings.roundedLines) do line.Visible = false end
    for _, line in ipairs(self._drawings.dashedOutlines) do line.Visible = false end
    for _, line in ipairs(self._drawings.dashedLines) do line.Visible = false end
    for _, line in ipairs(self._skeletonOutlineLines) do line.Visible = false end
    for _, line in ipairs(self._skeletonLines) do line.Visible = false end
    if self._highlight then
        self._highlight.Enabled = false
    end
end

function ESPObject:destroy()
    local function removeDrawing(drawing)
        pcall(function()
            drawing:Remove()
        end)
    end

    removeDrawing(self._drawings.box)
    removeDrawing(self._drawings.boxOutline)
    removeDrawing(self._drawings.nameLabel)
    removeDrawing(self._drawings.distLabel)
    removeDrawing(self._drawings.healthBarBgOutline)
    removeDrawing(self._drawings.healthBarBg)
    removeDrawing(self._drawings.healthBarFill)
    removeDrawing(self._drawings.snaplineOutline)
    removeDrawing(self._drawings.snapline)
    removeDrawing(self._drawings.headDotOutline)
    removeDrawing(self._drawings.headDot)
    removeDrawing(self._drawings.lookDirectionOutline)
    removeDrawing(self._drawings.lookDirection)
    for _, line in ipairs(self._drawings.lookDirectionArrowOutlines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.lookDirectionArrows) do removeDrawing(line) end

    for _, line in ipairs(self._drawings.cornerOutlines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.cornerLines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.roundedOutlines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.roundedLines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.dashedOutlines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.dashedLines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.box3DOutlines) do removeDrawing(line) end
    for _, line in ipairs(self._drawings.box3DLines) do removeDrawing(line) end
    for _, line in ipairs(self._skeletonOutlineLines) do removeDrawing(line) end
    for _, line in ipairs(self._skeletonLines) do removeDrawing(line) end

    if self._highlight then
        pcall(function()
            self._highlight:Destroy()
        end)
    end

    if self._profileGui and self._profileGui.ScreenGui then
        pcall(function()
            self._profileGui.ScreenGui:Destroy()
        end)
    end
end

