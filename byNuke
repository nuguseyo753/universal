    for _, line in ipairs(self._drawings.dashedLines) do line.Visible = false end
    for _, line in ipairs(self._drawings.box3DOutlines) do line.Visible = false end
    for _, line in ipairs(self._drawings.box3DLines) do line.Visible = false end
end

function ESPObject:_updateHeadDot(head, camera)
    local screenPos, visible = camera:WorldToViewportPoint(head.Position)
    if not visible then
        self._drawings.headDotOutline.Visible = false
        self._drawings.headDot.Visible = false
        return
    end

    local position = Vector2.new(screenPos.X, screenPos.Y)
    self._drawings.headDotOutline.Position = position
    self._drawings.headDotOutline.Radius = self._settings.HeadDotSize + 2
    self._drawings.headDotOutline.Color = self._settings.HeadDotOutlineColor
    self._drawings.headDotOutline.Visible = self._settings.HeadDotOutlineEnabled

    self._drawings.headDot.Position = position
    self._drawings.headDot.Radius = self._settings.HeadDotSize
    self._drawings.headDot.Color = self._settings.HeadDotColor
    self._drawings.headDot.Visible = true
end

function ESPObject:_getGuiParent()
    if gethui then
        local ok, gui = pcall(gethui)
        if ok and gui then
            return gui
        end
    end

    return LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui")
end

function ESPObject:_ensureProfileGui()
    if self._profileGui and self._profileGui.ScreenGui.Parent then
        return self._profileGui
    end

    local size = 28
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "UniversalProfileESP_" .. tostring(self._player.UserId)
    screenGui.IgnoreGuiInset = true
    screenGui.ResetOnSpawn = false
    screenGui.DisplayOrder = 999999
    screenGui.Parent = self:_getGuiParent()

    local frame = Instance.new("Frame")
    frame.Name = "Profile"
    frame.AnchorPoint = Vector2.new(0.5, 0)
    frame.Size = UDim2.fromOffset(size + 4, size + 4)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BorderSizePixel = 0
    frame.Visible = false
    frame.Parent = screenGui

    local frameCorner = Instance.new("UICorner")
    frameCorner.CornerRadius = UDim.new(1, 0)
    frameCorner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Thickness = 1
    stroke.Parent = frame

    local image = Instance.new("ImageLabel")
    image.Name = "Headshot"
    image.AnchorPoint = Vector2.new(0.5, 0.5)
    image.Position = UDim2.fromScale(0.5, 0.5)
    image.Size = UDim2.fromOffset(size, size)
    image.BackgroundTransparency = 1
    image.Image = ""
    image.Parent = frame

    local imageCorner = Instance.new("UICorner")
    imageCorner.CornerRadius = UDim.new(1, 0)
    imageCorner.Parent = image

    self._profileGui = {
        ScreenGui = screenGui,
        Frame = frame,
        Image = image,
        Stroke = stroke,
        Size = size,
    }

    task.spawn(function()
        local ok, content = pcall(function()
            return Players:GetUserThumbnailAsync(self._player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
        end)
        if ok and content and self._profileGui and self._profileGui.Image then
            self._profileGui.Image.Image = content
        end
    end)

    return self._profileGui
end

function ESPObject:_hideProfile()
    if self._profileGui then
        self._profileGui.Frame.Visible = false
    end
end

function ESPObject:_updateProfile(position, bottomY)
    local profileGui = self:_ensureProfileGui()
    profileGui.Frame.Position = UDim2.fromOffset(position.X, bottomY - profileGui.Size - 4)
    profileGui.Frame.Visible = true
end

function ESPObject:_updateLookDirection(head, camera)
    local startPos, startVisible = camera:WorldToViewportPoint(head.Position)
    local endPos, endVisible = camera:WorldToViewportPoint(head.Position + head.CFrame.LookVector * self._settings.LookDirectionLength)
    if not startVisible or not endVisible then
        self._drawings.lookDirectionOutline.Visible = false
        self._drawings.lookDirection.Visible = false
        return
    end

    local from = Vector2.new(startPos.X, startPos.Y)
    local to = Vector2.new(endPos.X, endPos.Y)

    local direction = to - from
    local unit = direction.Magnitude > 0 and direction.Unit or Vector2.new(0, -1)
    local perpendicular = Vector2.new(-unit.Y, unit.X)
    local arrowLength = math.clamp(direction.Magnitude * 0.25, 8, 18)
    local arrowWidth = arrowLength * 0.45
    local arrowPoints = {
        to - unit * arrowLength + perpendicular * arrowWidth,
        to - unit * arrowLength - perpendicular * arrowWidth,
    }

    self._drawings.lookDirectionOutline.From = from
    self._drawings.lookDirectionOutline.To = to
    self._drawings.lookDirectionOutline.Color = self._settings.LookDirectionOutlineColor
    self._drawings.lookDirectionOutline.Thickness = self._settings.LookDirectionThickness + self._settings.OutlineThickness
    self._drawings.lookDirectionOutline.Visible = self._settings.LookDirectionOutlineEnabled

    self._drawings.lookDirection.From = from
    self._drawings.lookDirection.To = to
    self._drawings.lookDirection.Color = self._settings.LookDirectionColor
    self._drawings.lookDirection.Thickness = self._settings.LookDirectionThickness
    self._drawings.lookDirection.Visible = true

    for index, point in ipairs(arrowPoints) do
        self._drawings.lookDirectionArrowOutlines[index].From = to
        self._drawings.lookDirectionArrowOutlines[index].To = point
        self._drawings.lookDirectionArrowOutlines[index].Color = self._settings.LookDirectionOutlineColor
        self._drawings.lookDirectionArrowOutlines[index].Thickness = self._settings.LookDirectionThickness + self._settings.OutlineThickness
        self._drawings.lookDirectionArrowOutlines[index].Visible = self._settings.LookDirectionOutlineEnabled

        self._drawings.lookDirectionArrows[index].From = to
        self._drawings.lookDirectionArrows[index].To = point
        self._drawings.lookDirectionArrows[index].Color = self._settings.LookDirectionColor
        self._drawings.lookDirectionArrows[index].Thickness = self._settings.LookDirectionThickness
        self._drawings.lookDirectionArrows[index].Visible = true
    end
end

