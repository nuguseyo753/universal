function App:_setupESP()
    local function onPlayerAdded(player)
        if player ~= LocalPlayer then
            self._espObjects[player] = ESPObject.new(player, self._espSettings)
        end
    end

    local function onPlayerRemoving(player)
        self:_restorePlayerHitbox(player)
        if self._espObjects[player] then
            self._espObjects[player]:destroy()
            self._espObjects[player] = nil
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        onPlayerAdded(player)
    end

    self:_connect(Players.PlayerAdded, onPlayerAdded)
    self:_connect(Players.PlayerRemoving, onPlayerRemoving)

    self:_connect(RunService.RenderStepped, function()
        if not self._espEnabled then
            if self._espWasEnabled then
                self:_clearESP()
                self._espWasEnabled = false
            end
            return
        end

        self._espWasEnabled = true

        local camera = Workspace.CurrentCamera
        for player, object in pairs(self._espObjects) do
            local teammate = self._espSettings.TeamCheck and self:_isTeammate(player)
            local ok = pcall(function()
                object:update(camera, LocalPlayer, teammate)
            end)
            if not ok then
                object:hide()
            end
        end
    end)
end

function App:_setupPlayer()
    self:_connect(LocalPlayer.CharacterAdded, function()
        task.wait(0.5)
        self:_applyPlayerSettings()
        if self._playerSettings.SemiInvisible then
            self:_startSemiInvisible()
        end
    end)

    self:_connect(UserInputService.JumpRequest, function()
        if not self._playerSettings.InfiniteJump then
            return
        end

        local humanoid = self:_getLocalHumanoid()
        if humanoid and humanoid.Health > 0 then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end)

    self:_connect(RunService.Stepped, function(_, deltaTime)
        self:_applyPlayerSettings()

        local humanoid, character = self:_getLocalHumanoid()
        local root = character and character:FindFirstChild("HumanoidRootPart")

        if root and self._playerSettings.Spinbot then
            root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(self._playerSettings.SpinSpeed), 0)
        end

        if root and humanoid and self._playerSettings.Fly then
            self:_updateFly(humanoid, root, deltaTime)
        end

        if not self._playerSettings.Noclip then
            return
        end

        if not character then
            return
        end

        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                if self._playerState.noclipParts[part] == nil then
                    self._playerState.noclipParts[part] = part.CanCollide
                end
                part.CanCollide = false
            end
        end
    end)
end

function App:_setupMisc()
    self:_connect(LocalPlayer.Idled, function()
        if not self._miscSettings.AntiAFK then
            return
        end

        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)

    self:_connect(RunService.RenderStepped, function(deltaTime)
        local now = tick()

        if (self._miscSettings.Fullbright or self._miscSettings.NoFog) and now - self._miscState.lightingLastUpdate >= 0.5 then
            self._miscState.lightingLastUpdate = now
            self:_applyMiscSettings()
        end

        if self._miscSettings.AntiFling and now - self._miscState.antiFlingLastUpdate >= 0.1 then
            self._miscState.antiFlingLastUpdate = now
            local _, character = self:_getLocalHumanoid()
            if character then
                for _, part in ipairs(character:GetDescendants()) do
                    if part:IsA("BasePart") and part.AssemblyLinearVelocity.Magnitude > 120 then
                        part.AssemblyLinearVelocity = Vector3.zero
                        part.AssemblyAngularVelocity = Vector3.zero
                    end
                end
            end
        end

        if self._miscSettings.HitboxExpander or next(self._miscState.hitboxes) then
            self:_applyHitboxExpander(deltaTime)
        end
    end)

    self:_connect(Workspace.DescendantAdded, function(object)
        if not self._miscSettings.LowGraphics or not object:IsA("BasePart") then
            return
        end

        self._miscState.lowGraphicsParts[object] = {
            Material = object.Material,
            Reflectance = object.Reflectance,
            CastShadow = object.CastShadow,
        }

        object.Material = Enum.Material.SmoothPlastic
        object.Reflectance = 0
        object.CastShadow = false
    end)
end

function App:_setupAimbot()
    self._fovFillCircle = Drawing.new("Circle")
    self._fovFillCircle.Visible = false
    self._fovFillCircle.Color = self._aimbotSettings.FOVColor
    self._fovFillCircle.Filled = true
    self._fovFillCircle.NumSides = 64

    self._fovOutlineCircle = Drawing.new("Circle")
    self._fovOutlineCircle.Visible = false
    self._fovOutlineCircle.Color = Color3.fromRGB(0, 0, 0)
    self._fovOutlineCircle.Thickness = 3
    self._fovOutlineCircle.Filled = false
    self._fovOutlineCircle.NumSides = 64

    self._fovCircle = Drawing.new("Circle")
    self._fovCircle.Visible = false
    self._fovCircle.Color = self._aimbotSettings.FOVColor
    self._fovCircle.Thickness = 1
    self._fovCircle.Filled = false
    self._fovCircle.NumSides = 64
    self._fovCircle.Transparency = 0.8

    self._silentFOVOutlineCircle = Drawing.new("Circle")
    self._silentFOVOutlineCircle.Visible = false
    self._silentFOVOutlineCircle.Color = Color3.fromRGB(0, 0, 0)
    self._silentFOVOutlineCircle.Thickness = 3
    self._silentFOVOutlineCircle.Filled = false
    self._silentFOVOutlineCircle.NumSides = 64

    self._silentFOVCircle = Drawing.new("Circle")
    self._silentFOVCircle.Visible = false
    self._silentFOVCircle.Color = self._aimbotSettings.SilentAimColor
    self._silentFOVCircle.Thickness = 1
    self._silentFOVCircle.Filled = false
    self._silentFOVCircle.NumSides = 64

    self._triggerFOVOutlineCircle = Drawing.new("Circle")
    self._triggerFOVOutlineCircle.Visible = false
    self._triggerFOVOutlineCircle.Color = Color3.fromRGB(0, 0, 0)
    self._triggerFOVOutlineCircle.Thickness = 3
    self._triggerFOVOutlineCircle.Filled = false
    self._triggerFOVOutlineCircle.NumSides = 64

    self._triggerFOVCircle = Drawing.new("Circle")
    self._triggerFOVCircle.Visible = false
    self._triggerFOVCircle.Color = self._aimbotSettings.TriggerbotColor
    self._triggerFOVCircle.Thickness = 1
    self._triggerFOVCircle.Filled = false
    self._triggerFOVCircle.NumSides = 64

    for _ = 1, 48 do
        local outline = Drawing.new("Line")
        outline.Visible = false
        outline.Color = Color3.fromRGB(0, 0, 0)
        outline.Thickness = 3
        table.insert(self._fovDashOutlineSegments, outline)

        local line = Drawing.new("Line")
        line.Visible = false
        line.Color = self._aimbotSettings.FOVColor
        line.Thickness = 1
        table.insert(self._fovDashSegments, line)
    end

    self:_connect(UserInputService.InputBegan, function(input, gameProcessed)
        if gameProcessed then
            return
        end

        if self._aimbotSettings.SilentAimEnabled and input.UserInputType == Enum.UserInputType.MouseButton1 then
            self:_processSilentAimClick()
        end

        if not self._aimbotSettings.Enabled then
            return
        end

        if self:_inputMatchesActivation(input) then
            self._aimbotState.isActive = true
        end
    end)

    self:_connect(UserInputService.InputEnded, function(input)
        if not self._aimbotSettings.Enabled then
            return
        end

        if self:_inputMatchesActivation(input) then
            self._aimbotState.isActive = false
            if not self._aimbotSettings.StickyTarget then
                self._aimbotState.currentTarget = nil
            end
        end
    end)

    self:_connect(RunService.RenderStepped, function()
        local camera = Workspace.CurrentCamera
        local mousePosition = UserInputService:GetMouseLocation()
        local aimOrigin = self:_getAimFOVOrigin(camera)

        self:_updateFOVDrawings(camera)

        if self._aimbotSettings.Enabled and self._aimbotSettings.TriggerbotEnabled then
            self:_processTriggerbot(camera)
        end

        if not self._aimbotSettings.Enabled or not self._aimbotState.isActive then
            return
        end

        local target = self:_getAimbotTarget(camera, aimOrigin)
        if not target then
            self._aimbotState.currentTarget = nil
            return
        end

        self._aimbotState.currentTarget = target
        local aimPart = self:_getAimPart(target)
        if not aimPart then
            return
        end

        local aimPosition = aimPart.Position
        if self._aimbotSettings.Prediction > 0 then
            local velocity = aimPart.AssemblyLinearVelocity or Vector3.zero
            aimPosition = aimPosition + velocity * self._aimbotSettings.Prediction
        end

        local alpha = 1 / math.max(self._aimbotSettings.Smoothness, 1)
        if self._aimbotSettings.LookAtView then
            local targetCFrame = CFrame.lookAt(camera.CFrame.Position, aimPosition)
            camera.CFrame = camera.CFrame:Lerp(targetCFrame, alpha)
        else
            local targetScreen = camera:WorldToViewportPoint(aimPosition)
            local delta = Vector2.new(targetScreen.X, targetScreen.Y) - aimOrigin
            local moveBy = delta * alpha
            mousemoverel(moveBy.X, moveBy.Y)
        end
    end)
end

function App:destroy()
    if self._unloading then
        return
    end
    self._unloading = true

    self._espEnabled = false
    self._aimbotSettings.Enabled = false
    self._aimbotSettings.SilentAimEnabled = false
    self._aimbotState.isActive = false
    self._aimbotState.currentTarget = nil

    self._playerSettings.WalkSpeedEnabled = false
    self._playerSettings.JumpPowerEnabled = false
    self._playerSettings.HipHeightEnabled = false
    self._playerSettings.InfiniteJump = false
    self._playerSettings.Noclip = false
    self._playerSettings.CameraFOVEnabled = false
    self._playerSettings.GravityEnabled = false
    self._playerSettings.Spinbot = false
    self._playerSettings.Fly = false
    self._playerSettings.SemiInvisible = false

    self._miscSettings.AntiAFK = false
    self._miscSettings.AntiFling = false
    self._miscSettings.Fullbright = false
    self._miscSettings.NoFog = false
    self._miscSettings.LowGraphics = false
    self._miscSettings.HitboxExpander = false

    self:_restoreWalkSpeed()
    self:_restoreJumpPower()
    self:_restoreHipHeight()
    self:_restoreNoclip()
    self:_restoreCameraFOV()
    self:_restoreGravity()
    self:_stopFly()
    self:_stopSemiInvisible()
    self:_restoreMiscSettings()
    self:_restoreLowGraphics()
    self:_restoreHitboxes()

    for _, connection in ipairs(self._connections) do
        pcall(function()
            connection:Disconnect()
        end)
    end

    for _, object in pairs(self._espObjects) do
        object:destroy()
    end

    if self._fovCircle then
        pcall(function()
            self._fovCircle.Visible = false
            self._fovCircle:Remove()
        end)
    end

    if self._fovOutlineCircle then
        pcall(function()
            self._fovOutlineCircle.Visible = false
            self._fovOutlineCircle:Remove()
        end)
    end

    if self._fovFillCircle then
        pcall(function()
            self._fovFillCircle.Visible = false
            self._fovFillCircle:Remove()
        end)
    end

    if self._silentFOVCircle then
        pcall(function()
            self._silentFOVCircle.Visible = false
            self._silentFOVCircle:Remove()
        end)
    end

    if self._silentFOVOutlineCircle then
        pcall(function()
            self._silentFOVOutlineCircle.Visible = false
            self._silentFOVOutlineCircle:Remove()
        end)
    end

    if self._triggerFOVCircle then
        pcall(function()
            self._triggerFOVCircle.Visible = false
            self._triggerFOVCircle:Remove()
        end)
    end

    if self._triggerFOVOutlineCircle then
        pcall(function()
            self._triggerFOVOutlineCircle.Visible = false
            self._triggerFOVOutlineCircle:Remove()
        end)
    end

    for _, line in ipairs(self._fovDashSegments) do
        pcall(function()
            line.Visible = false
            line:Remove()
        end)
    end

    for _, line in ipairs(self._fovDashOutlineSegments) do
        pcall(function()
            line.Visible = false
            line:Remove()
        end)
    end

    if Library and Library.Unload == self._libraryUnloadWrapper then
        Library.Unload = self._originalLibraryUnload
    end

    self._connections = {}
    self._espObjects = {}
    if getgenv().BlatantLibraryUI == self then
        getgenv().BlatantLibraryUI = nil
    end
end

if getgenv().BlatantLibraryUI then
    pcall(function()
        getgenv().BlatantLibraryUI:destroy()
    end)
end

local blatantLibraryUI = App.new()
getgenv().BlatantLibraryUI = blatantLibraryUI

return blatantLibraryUI
