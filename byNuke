function App:_connect(signal, callback)
    local connection = signal:Connect(callback)
    table.insert(self._connections, connection)
    return connection
end

function App:_hookLibraryUnload()
    local app = self
    self._libraryUnloadWrapper = function(librarySelf, ...)
        if not app._unloading then
            app:destroy()
        end

        if app._originalLibraryUnload then
            return app._originalLibraryUnload(librarySelf, ...)
        end
    end

    Library.Unload = self._libraryUnloadWrapper
end

function App:_isTeammate(player)
    if not player.Team or not LocalPlayer.Team then
        return false
    end
    return player.Team == LocalPlayer.Team
end

function App:_clearESP()
    for _, object in pairs(self._espObjects) do
        object:hide()
    end
end

