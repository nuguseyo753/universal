function App:_isVisible(camera, part)
    local origin = camera.CFrame.Position
    local direction = part.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude

    local ignore = {}
    if LocalPlayer.Character then
        table.insert(ignore, LocalPlayer.Character)
    end
    if part.Parent then
        table.insert(ignore, part.Parent)
    end
    params.FilterDescendantsInstances = ignore

    return Workspace:Raycast(origin, direction, params) == nil
end

function App:_getAimPart(player)
    if not player.Character then
        return nil
    end

    local bodyAim = self._aimbotSettings.BodyAim
    if bodyAim == "Nearest" then
        local camera = Workspace.CurrentCamera
        local mousePosition = UserInputService:GetMouseLocation()
        local nearestPart
        local nearestDistance = math.huge

        for _, child in ipairs(player.Character:GetChildren()) do
            if child:IsA("BasePart") then
                local screenPos, visible = camera:WorldToViewportPoint(child.Position)
                if visible then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePosition).Magnitude
                    if distance < nearestDistance then
                        nearestDistance = distance
                        nearestPart = child
                    end
                end
            end
        end

        return nearestPart
    end

    local targetName = bodyAim
    if bodyAim == "Torso" then
        targetName = player.Character:FindFirstChild("UpperTorso") and "UpperTorso" or "Torso"
    end

    return player.Character:FindFirstChild(targetName)
end

function App:_getAimbotTarget(camera, mousePosition)
    if self._aimbotSettings.StickyTarget and self._aimbotState.currentTarget then
        local target = self._aimbotState.currentTarget
        if target.Character then
            local humanoid = target.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local aimPart = self:_getAimPart(target)
                if aimPart then
                    local screenPos, visible = camera:WorldToViewportPoint(aimPart.Position)
                    if visible then
                        local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePosition).Magnitude
                        if distance <= self._aimbotSettings.FOV then
                            if not self._aimbotSettings.WallCheck or self:_isVisible(camera, aimPart) then
                                return target
                            end
                        end
                    end
                end
            end
        end
        self._aimbotState.currentTarget = nil
    end

    local bestTarget
    local bestDistance = self._aimbotSettings.FOV

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if self._aimbotSettings.TeamCheck and self:_isTeammate(player) then
                continue
            end

            local character = player.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            if not humanoid or humanoid.Health <= 0 then
                continue
            end

            local aimPart = self:_getAimPart(player)
            if not aimPart then
                continue
            end

            local screenPos, visible = camera:WorldToViewportPoint(aimPart.Position)
            if not visible then
                continue
            end

            local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePosition).Magnitude
            if distance > bestDistance then
                continue
            end

            if self._aimbotSettings.WallCheck and not self:_isVisible(camera, aimPart) then
                continue
            end

            bestDistance = distance
            bestTarget = player
        end
    end

    return bestTarget
end

function App:_getAimFOVOrigin(camera)
    if self._aimbotSettings.FOVOrigin == "Center" then
        local viewportSize = camera and camera.ViewportSize or Vector2.new(1920, 1080)
        return viewportSize / 2
    end

    return UserInputService:GetMouseLocation()
end

function App:_getSilentAimTarget(camera)
    local origin = self:_getAimFOVOrigin(camera)
    local oldFOV = self._aimbotSettings.FOV
    self._aimbotSettings.FOV = self._aimbotSettings.SilentAimFOV
    local target = self:_getAimbotTarget(camera, origin)
    self._aimbotSettings.FOV = oldFOV
    return target
end

function App:_getSilentAimPart()
    if not self._aimbotSettings.SilentAimEnabled then
        return nil
    end

    local now = tick()
    if self._silentAimCache.part and self._silentAimCache.part.Parent and now < self._silentAimCache.expires then
        return self._silentAimCache.part
    end

    if math.random(1, 100) > self._aimbotSettings.SilentAimHitChance then
        return nil
    end

    local camera = Workspace.CurrentCamera
    if not camera then
        return nil
    end

    local target = self:_getSilentAimTarget(camera)
    if not target then
        return nil
    end

    local part = self:_getAimPart(target)
    self._silentAimCache.part = part
    self._silentAimCache.expires = now + 0.05
    return part
end

function App:_setupSilentAimHook()
    if self._silentAimHooked or not getgenv or not hookmetamethod or not newcclosure or not checkcaller then
        return
    end

    self._silentAimHooked = true
    getgenv().BlatantSilentAimApp = self
    if getgenv().BlatantSilentAimHooked then
        return
    end
    getgenv().BlatantSilentAimHooked = true

    local mouse = LocalPlayer:GetMouse()
    local oldIndex
    oldIndex = hookmetamethod(game, "__index", newcclosure(function(object, key)
        if not checkcaller() and object == mouse and (key == "Hit" or key == "Target") then
            local app = getgenv().BlatantSilentAimApp
            local part = app and app:_getSilentAimPart()
            if part then
                return key == "Hit" and part.CFrame or part
            end
        end

        return oldIndex(object, key)
    end))
end

function App:_processSilentAimClick()
    self._silentAimCache.part = nil
    self._silentAimCache.expires = 0
    self:_getSilentAimPart()
end

function App:_hideFOVDrawings()
    self._fovFadeProgress = 0
    self._lastFOVFadeUpdate = tick()
    if self._fovCircle then
        self._fovCircle.Visible = false
    end
    if self._fovOutlineCircle then
        self._fovOutlineCircle.Visible = false
    end
    if self._fovFillCircle then
        self._fovFillCircle.Visible = false
    end
    for _, line in ipairs(self._fovDashOutlineSegments) do
        line.Visible = false
    end
    for _, line in ipairs(self._fovDashSegments) do
        line.Visible = false
    end
    if self._silentFOVCircle then self._silentFOVCircle.Visible = false end
    if self._silentFOVOutlineCircle then self._silentFOVOutlineCircle.Visible = false end
    if self._triggerFOVCircle then self._triggerFOVCircle.Visible = false end
    if self._triggerFOVOutlineCircle then self._triggerFOVOutlineCircle.Visible = false end
end

function App:_drawSimpleFOV(circle, outline, position, radius, color, fade)
    if outline then
        outline.Position = position
        outline.Radius = radius
        outline.Color = Color3.fromRGB(0, 0, 0)
        outline.Thickness = 3
        outline.Transparency = 0.8 * fade
        outline.Visible = true
    end

    circle.Position = position
    circle.Radius = radius
    circle.Color = color
    circle.Thickness = 1
    circle.Transparency = 0.8 * fade
    circle.Visible = true
end

function App:_drawDashedFOV(mousePosition)
    local radius = self._aimbotSettings.FOV
    local segments = #self._fovDashSegments
    local dashRatio = 0.55
    local lineAlpha = (self._aimbotSettings.FOVTransparency / 100) * self._fovFadeProgress

    for index, line in ipairs(self._fovDashSegments) do
        local startAngle = ((index - 1) / segments) * math.pi * 2
        local endAngle = startAngle + ((math.pi * 2) / segments) * dashRatio
        local from = mousePosition + Vector2.new(math.cos(startAngle), math.sin(startAngle)) * radius
        local to = mousePosition + Vector2.new(math.cos(endAngle), math.sin(endAngle)) * radius

        local outline = self._fovDashOutlineSegments[index]
        if outline then
            outline.From = from
            outline.To = to
            outline.Color = Color3.fromRGB(0, 0, 0)
            outline.Thickness = self._aimbotSettings.FOVThickness + 2
            outline.Transparency = lineAlpha
            outline.Visible = self._aimbotSettings.FOVOutline
        end

        line.From = from
        line.To = to
        line.Color = self._aimbotSettings.FOVColor
        line.Thickness = self._aimbotSettings.FOVThickness
        line.Transparency = lineAlpha
        line.Visible = true
    end
end

function App:_updateFOVDrawings(camera)
    local origin = self:_getAimFOVOrigin(camera)
    local showAimFOV = self._aimbotSettings.Enabled and self._aimbotSettings.ShowFOV
    local showSilentFOV = self._aimbotSettings.SilentAimEnabled and self._aimbotSettings.SilentAimShowFOV
    local showTriggerFOV = self._aimbotSettings.TriggerbotEnabled and self._aimbotSettings.TriggerbotShowFOV
    if not showAimFOV and not showSilentFOV and not showTriggerFOV then
        self:_hideFOVDrawings()
        return
    end

    local now = tick()
    local delta = math.clamp(now - self._lastFOVFadeUpdate, 0, 0.1)
    self._lastFOVFadeUpdate = now
    self._fovFadeProgress = math.clamp(self._fovFadeProgress + delta / 0.45, 0, 1)

    local outlineVisible = self._aimbotSettings.FOVOutline
    local style = self._aimbotSettings.FOVStyle
    local lineAlpha = (self._aimbotSettings.FOVTransparency / 100) * self._fovFadeProgress
    local fillAlpha = (self._aimbotSettings.FOVFillTransparency / 100) * self._fovFadeProgress

    self._fovFillCircle.Position = origin
    self._fovFillCircle.Radius = self._aimbotSettings.FOV
    self._fovFillCircle.Color = self._aimbotSettings.FOVColor
    self._fovFillCircle.Transparency = fillAlpha
    self._fovFillCircle.Visible = showAimFOV and self._aimbotSettings.FOVFilled

    self._fovOutlineCircle.Position = origin
    self._fovOutlineCircle.Radius = self._aimbotSettings.FOV
    self._fovOutlineCircle.Color = Color3.fromRGB(0, 0, 0)
    self._fovOutlineCircle.Thickness = self._aimbotSettings.FOVThickness + 2
    self._fovOutlineCircle.Transparency = lineAlpha
    self._fovOutlineCircle.Visible = showAimFOV and outlineVisible and style == "Solid"

    self._fovCircle.Position = origin
    self._fovCircle.Radius = self._aimbotSettings.FOV
    self._fovCircle.Color = self._aimbotSettings.FOVColor
    self._fovCircle.Thickness = self._aimbotSettings.FOVThickness
    self._fovCircle.Transparency = lineAlpha
    self._fovCircle.Visible = showAimFOV and style == "Solid"

    if showAimFOV and style == "Dashed" then
        self:_drawDashedFOV(origin)
    else
        for _, line in ipairs(self._fovDashOutlineSegments) do
            line.Visible = false
        end
        for _, line in ipairs(self._fovDashSegments) do
            line.Visible = false
        end
    end

    if showSilentFOV then
        self._silentFOVFadeProgress = math.clamp(self._silentFOVFadeProgress + delta / 0.45, 0, 1)
        self:_drawSimpleFOV(self._silentFOVCircle, self._silentFOVOutlineCircle, origin, self._aimbotSettings.SilentAimFOV, self._aimbotSettings.SilentAimColor, self._silentFOVFadeProgress)
    else
        self._silentFOVFadeProgress = 0
        if self._silentFOVCircle then self._silentFOVCircle.Visible = false end
        if self._silentFOVOutlineCircle then self._silentFOVOutlineCircle.Visible = false end
    end

    if showTriggerFOV then
        self._triggerFOVFadeProgress = math.clamp(self._triggerFOVFadeProgress + delta / 0.45, 0, 1)
        self:_drawSimpleFOV(self._triggerFOVCircle, self._triggerFOVOutlineCircle, origin, self._aimbotSettings.TriggerbotFOV, self._aimbotSettings.TriggerbotColor, self._triggerFOVFadeProgress)
    else
        self._triggerFOVFadeProgress = 0
        if self._triggerFOVCircle then self._triggerFOVCircle.Visible = false end
        if self._triggerFOVOutlineCircle then self._triggerFOVOutlineCircle.Visible = false end
    end
end

function App:_processTriggerbot(camera)
    local now = tick()
    local delaySeconds = self._aimbotSettings.TriggerbotDelay / 1000
    if now - self._aimbotState.triggerbotCooldown < delaySeconds then
        return
    end

    local triggerRadius = self._aimbotSettings.TriggerbotFOV
    local screenCenter = self:_getAimFOVOrigin(camera)
    local bestPlayer
    local bestDistance = triggerRadius

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then
            continue
        end
        if self._aimbotSettings.TeamCheck and self:_isTeammate(player) then
            continue
        end

        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            continue
        end

        for _, partName in ipairs({"Head", "UpperTorso", "Torso", "HumanoidRootPart", "LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg"}) do
            local part = character:FindFirstChild(partName)
            if not part then
                continue
            end

            local screenPos, visible = camera:WorldToViewportPoint(part.Position)
            if not visible then
                continue
            end

            local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
            local partScreenSize = 0
            pcall(function()
                local topPos = camera:WorldToViewportPoint(part.Position + Vector3.new(0, part.Size.Y / 2, 0))
                local bottomPos = camera:WorldToViewportPoint(part.Position - Vector3.new(0, part.Size.Y / 2, 0))
                partScreenSize = math.abs(topPos.Y - bottomPos.Y) / 2
            end)

            local effectiveRadius = math.max(partScreenSize, 5)
            if distance <= effectiveRadius + triggerRadius * 0.3 and distance < bestDistance then
                if self._aimbotSettings.WallCheck and not self:_isVisible(camera, part) then
                    continue
                end
                bestDistance = distance
                bestPlayer = player
                break
            end
        end
    end

    if bestPlayer then
        self._aimbotState.triggerbotCooldown = now
        task.spawn(function()
            mouse1press()
            task.wait(0.03 + math.random() * 0.02)
            mouse1release()
        end)
    end
end

function App:_getLocalHumanoid()
    local character = LocalPlayer.Character
    if not character then
