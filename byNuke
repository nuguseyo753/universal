function App:_clearFlyMovers()
    if self._playerState.flyBodyVelocity then
        self._playerState.flyBodyVelocity:Destroy()
        self._playerState.flyBodyVelocity = nil
    end

    if self._playerState.flyBodyGyro then
        self._playerState.flyBodyGyro:Destroy()
        self._playerState.flyBodyGyro = nil
    end
end

function App:_stopFly()
    local humanoid, character = self:_getLocalHumanoid()
    local root = character and character:FindFirstChild("HumanoidRootPart")

    self:_clearFlyMovers()

    if root then
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        pcall(function()
            root.Velocity = Vector3.zero
            root.RotVelocity = Vector3.zero
        end)
    end

    if humanoid then
        humanoid.PlatformStand = false
        humanoid.AutoRotate = true
        humanoid.Sit = false
        humanoid:Move(Vector3.zero, false)
        if self._playerSettings.WalkSpeedEnabled then
            humanoid.WalkSpeed = self._playerSettings.WalkSpeed
        else
            self:_restoreWalkSpeed()
        end
        pcall(function()
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end)
        task.defer(function()
            if humanoid.Parent then
                pcall(function()
                    humanoid:ChangeState(Enum.HumanoidStateType.Running)
                end)
            end
        end)
    end
end

function App:_getFlyMoveDirection(camera)
    if not camera then
        return Vector3.zero
    end

    local moveDirection = Vector3.zero
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection += camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection -= camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection += camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection -= camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection += Vector3.yAxis end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDirection -= Vector3.yAxis end

    if moveDirection.Magnitude > 0 then
        return moveDirection.Unit
    end

    return Vector3.zero
end

function App:_updateFly(humanoid, root, deltaTime)
    local camera = Workspace.CurrentCamera
    local direction = self:_getFlyMoveDirection(camera)
    local mode = self._playerSettings.FlyMode or "CFrame"
    local speed = self._playerSettings.FlySpeed

    if mode ~= "BodyMover" then
        self:_clearFlyMovers()
    end

    if mode == "CFrame" then
        humanoid.PlatformStand = false
        humanoid.AutoRotate = true
        humanoid:Move(Vector3.zero, false)
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        if direction.Magnitude > 0 then
            root.CFrame = root.CFrame + (direction * speed * (deltaTime or 0.016))
        end
    elseif mode == "BodyMover" then
        humanoid.PlatformStand = true
        humanoid.AutoRotate = false
        if not self._playerState.flyBodyVelocity or self._playerState.flyBodyVelocity.Parent ~= root then
            self:_clearFlyMovers()
            local bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            bodyVelocity.P = 9e4
            bodyVelocity.Parent = root
            self._playerState.flyBodyVelocity = bodyVelocity

            local bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            bodyGyro.P = 9e4
            bodyGyro.Parent = root
            self._playerState.flyBodyGyro = bodyGyro
        end
        self._playerState.flyBodyVelocity.Velocity = direction * speed
        if camera then
            self._playerState.flyBodyGyro.CFrame = camera.CFrame
        end
    end
end

function App:_stopSemiInvisible()
    for _, connection in ipairs(self._playerState.semiInvisibleConnections) do
        pcall(function()
            connection:Disconnect()
        end)
    end
    self._playerState.semiInvisibleConnections = {}

    if self._playerState.semiInvisibleUpsideDown then
        pcall(function()
            self._playerState.semiInvisibleUpsideDown:Disconnect()
        end)
        self._playerState.semiInvisibleUpsideDown = nil
    end

    if self._playerState.semiInvisibleTrack then
        pcall(function()
            self._playerState.semiInvisibleTrack:Stop()
        end)
        self._playerState.semiInvisibleTrack = nil
    end

    local humanoid = self:_getLocalHumanoid()
    if humanoid then
        humanoid.CameraOffset = Vector3.zero
    end
end

function App:_startSemiInvisible()
    self:_stopSemiInvisible()

    local humanoid, character = self:_getLocalHumanoid()
    if not humanoid or not character then
        return
    end

    local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
    local animation = Instance.new("Animation")
    animation.AnimationId = "rbxassetid://91133306449431"

    local ok, track = pcall(function()
        return animator:LoadAnimation(animation)
    end)
    if not ok or not track then
        return
    end

    self._playerState.semiInvisibleTrack = track
    track.Priority = Enum.AnimationPriority.Action4

    table.insert(self._playerState.semiInvisibleConnections, RunService.Heartbeat:Connect(function()
        if not self._playerSettings.SemiInvisible then
            return
        end

        if not track.IsPlaying then
            track:Play()
        end
        track:AdjustSpeed(0)
        track.TimePosition = 1
    end))

    table.insert(self._playerState.semiInvisibleConnections, RunService.RenderStepped:Connect(function()
        if track.IsPlaying then
            track:Stop()
        end
    end))

    self._playerState.semiInvisibleUpsideDown = RunService.Heartbeat:Connect(function()
        if not self._playerSettings.SemiInvisible then
            return
        end

        local root = character:FindFirstChild("HumanoidRootPart")
        if root and humanoid then
            local oldCFrame = root.CFrame
            local oldCameraOffset = humanoid.CameraOffset

            humanoid.CameraOffset = Vector3.new(0, -3, 0)
            root.CFrame = root.CFrame * CFrame.Angles(0, 0, math.rad(180))

            RunService.RenderStepped:Wait()

            root.CFrame = oldCFrame
            humanoid.CameraOffset = oldCameraOffset
        end
    end)
end

function App:_applyPlayerSettings()
    local humanoid = self:_getLocalHumanoid()
    if humanoid then
        self:_getHumanoidDefaults(humanoid)

        if self._playerSettings.WalkSpeedEnabled then
            humanoid.WalkSpeed = self._playerSettings.WalkSpeed
        end

        if self._playerSettings.JumpPowerEnabled then
            pcall(function()
                humanoid.UseJumpPower = true
            end)
            humanoid.JumpPower = self._playerSettings.JumpPower
        end

        if self._playerSettings.HipHeightEnabled then
            humanoid.HipHeight = self._playerSettings.HipHeight
        end
    end

    local camera = Workspace.CurrentCamera
    if camera and self._playerSettings.CameraFOVEnabled then
        if not self._playerState.cameraFOV then
            self._playerState.cameraFOV = camera.FieldOfView
        end
        camera.FieldOfView = self._playerSettings.CameraFOV
    end

    if self._playerSettings.GravityEnabled then
        Workspace.Gravity = self._playerSettings.Gravity
    end
end

function App:_applyMiscSettings()
    if (self._miscSettings.Fullbright or self._miscSettings.NoFog) and not self._miscState.lighting then
        self._miscState.lighting = {
            Brightness = Lighting.Brightness,
            ClockTime = Lighting.ClockTime,
            FogEnd = Lighting.FogEnd,
            GlobalShadows = Lighting.GlobalShadows,
            Ambient = Lighting.Ambient,
            OutdoorAmbient = Lighting.OutdoorAmbient,
        }
    end

    if self._miscSettings.Fullbright then
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.GlobalShadows = false
        Lighting.Ambient = Color3.fromRGB(255, 255, 255)
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    end

    if self._miscSettings.NoFog then
        Lighting.FogEnd = 100000
    end
end

function App:_restoreMiscSettings()
    local lighting = self._miscState.lighting
    if lighting then
