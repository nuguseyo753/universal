function App:_applyLowGraphics()
    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain and not self._miscState.terrain then
        self._miscState.terrain = {
            WaterWaveSize = terrain.WaterWaveSize,
            WaterWaveSpeed = terrain.WaterWaveSpeed,
            WaterReflectance = terrain.WaterReflectance,
            WaterTransparency = terrain.WaterTransparency,
        }
    end

    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 1
    end

    for _, object in ipairs(Workspace:GetDescendants()) do
        if object:IsA("BasePart") and not self._miscState.lowGraphicsParts[object] then
            self._miscState.lowGraphicsParts[object] = {
                Material = object.Material,
                Reflectance = object.Reflectance,
                CastShadow = object.CastShadow,
            }

            object.Material = Enum.Material.SmoothPlastic
            object.Reflectance = 0
            object.CastShadow = false
        end
    end
end

function App:_restoreLowGraphics()
    for part, defaults in pairs(self._miscState.lowGraphicsParts) do
        if part and part.Parent then
            pcall(function()
                part.Material = defaults.Material
                part.Reflectance = defaults.Reflectance
                part.CastShadow = defaults.CastShadow
            end)
        end
    end
    self._miscState.lowGraphicsParts = {}

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    if terrain and self._miscState.terrain then
        terrain.WaterWaveSize = self._miscState.terrain.WaterWaveSize
        terrain.WaterWaveSpeed = self._miscState.terrain.WaterWaveSpeed
        terrain.WaterReflectance = self._miscState.terrain.WaterReflectance
        terrain.WaterTransparency = self._miscState.terrain.WaterTransparency
    end
    self._miscState.terrain = nil
end

function App:_restoreHitboxes()
    for root, data in pairs(self._miscState.hitboxes) do
        if data.HitboxPart then
            pcall(function()
                data.HitboxPart:Destroy()
            end)
        end

        if root and root.Parent and data.RootDefaults then
            local defaults = data.RootDefaults
            pcall(function()
                root.Size = defaults.Size
                root.Transparency = defaults.Transparency
                root.Color = defaults.Color
                root.Material = defaults.Material
                root.CanCollide = defaults.CanCollide
                root.Massless = defaults.Massless
            end)
        end
    end
    self._miscState.hitboxes = {}
end

function App:_restorePlayerHitbox(player)
    local character = player and player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if root and self._miscState.hitboxes[root] then
        local data = self._miscState.hitboxes[root]
        if data.HitboxPart then
            pcall(function()
                data.HitboxPart:Destroy()
            end)
        end

        if data.RootDefaults then
            local defaults = data.RootDefaults
            pcall(function()
                root.Size = defaults.Size
                root.Transparency = defaults.Transparency
                root.Color = defaults.Color
                root.Material = defaults.Material
                root.CanCollide = defaults.CanCollide
                root.Massless = defaults.Massless
            end)
        end
        self._miscState.hitboxes[root] = nil
    end
end

function App:_createHitboxPart(root)
    local part = Instance.new("Part")
    part.Name = "UniversalHitbox"
    part.Anchored = true
    part.CanCollide = false
    part.CanTouch = false
    part.Massless = true
    part.Size = root.Size
    part.CFrame = root.CFrame
    part.Transparency = 1
    part.Color = Color3.fromRGB(255, 80, 80)
    part.Material = Enum.Material.ForceField
    pcall(function()
        part.CanQuery = true
    end)
    part.Parent = Workspace

    return part
end

function App:_normalizeLegacyHitboxRoot(root)
    if root.Size.X > 4 or root.Size.Y > 4 or root.Size.Z > 4 then
        pcall(function()
            root.Size = Vector3.new(2, 2, 1)
            root.Transparency = 1
            root.CanCollide = false
        end)
    end
end

function App:_applyHitboxExpander(deltaTime)
    if not self._miscSettings.HitboxExpander then
        if next(self._miscState.hitboxes) then
            self:_restoreHitboxes()
        end
        return
    end

    local size = math.clamp(self._miscSettings.HitboxSize or 8, 2, 50)
    local visible = self._miscSettings.HitboxVisible
    local targetSize = Vector3.new(size, size, size)
    local resizeAlpha = math.clamp((deltaTime or 0.016) * 10, 0, 1)

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            if root then
                self:_normalizeLegacyHitboxRoot(root)
                local data = self._miscState.hitboxes[root]
                if not data then
                    data = {
                        RootDefaults = {
                            Size = root.Size,
                            Transparency = root.Transparency,
                            Color = root.Color,
                            Material = root.Material,
                            CanCollide = root.CanCollide,
                            Massless = root.Massless,
                        },
                    }
                    self._miscState.hitboxes[root] = data
                end

                if not data.HitboxPart or not data.HitboxPart.Parent then
                    data.HitboxPart = self:_createHitboxPart(root)
                    if data.RootDefaults then
                        pcall(function()
                            root.Size = data.RootDefaults.Size
                            root.Transparency = data.RootDefaults.Transparency
                            root.Color = data.RootDefaults.Color
                            root.Material = data.RootDefaults.Material
                            root.CanCollide = data.RootDefaults.CanCollide
                            root.Massless = data.RootDefaults.Massless
                        end)
                    end
                end

                local hitboxPart = data.HitboxPart
                if hitboxPart then
                    pcall(function()
                        hitboxPart.Size = hitboxPart.Size:Lerp(targetSize, resizeAlpha)
                        hitboxPart.CFrame = root.CFrame
                        hitboxPart.Transparency = visible and 0.45 or 1
                        hitboxPart.Color = Color3.fromRGB(255, 80, 80)
                        hitboxPart.Material = Enum.Material.ForceField
                        hitboxPart.CanCollide = false
                        hitboxPart.CanTouch = false
                        hitboxPart.Massless = true
                        pcall(function()
                            hitboxPart.CanQuery = true
                        end)
                    end)
                end

                if data.RootDefaults then
                    pcall(function()
                        root.Size = data.RootDefaults.Size
                        root.Transparency = data.RootDefaults.Transparency
                        root.Color = data.RootDefaults.Color
                        root.Material = data.RootDefaults.Material
                        root.CanCollide = data.RootDefaults.CanCollide
                        root.Massless = data.RootDefaults.Massless
                    end)
                end
            end
        end
    end

    for root, data in pairs(self._miscState.hitboxes) do
        if not root or not root.Parent then
            if data.HitboxPart then
                pcall(function()
                    data.HitboxPart:Destroy()
                end)
            end
            self._miscState.hitboxes[root] = nil
        end
    end
end

function App:_setActivationKey(value)
    local key = value

    if type(key) == "boolean" then
        return
    end

    if type(key) == "table" then
        key = key.Key or key.key or key.Value or key.value
    end

    if typeof(key) == "EnumItem" then
        key = key.Name
    elseif type(key) == "string" then
        key = key:gsub("^Enum%.KeyCode%.", ""):gsub("^Enum%.UserInputType%.", "")
    end

    self._aimbotSettings.ActivationKey = key or "MouseButton2"
end

function App:_inputMatchesActivation(input)
    local key = self._aimbotSettings.ActivationKey

    if typeof(key) == "EnumItem" then
        return input.KeyCode == key or input.UserInputType == key
    end

    key = tostring(key)
    key = key:gsub("^Enum%.KeyCode%.", ""):gsub("^Enum%.UserInputType%.", "")

    local inputType
    pcall(function()
        inputType = Enum.UserInputType[key]
    end)
    if inputType and input.UserInputType == inputType then
        return true
    end

    local keyCode
    pcall(function()
        keyCode = Enum.KeyCode[key]
    end)
    return keyCode and input.KeyCode == keyCode
end

