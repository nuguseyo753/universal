function ESPObject:_setDrawingAlpha(drawing, alpha)
    pcall(function()
        drawing.Transparency = alpha
    end)
end

function ESPObject:_stepFeatureFade(feature, delta)
    self._featureFade[feature] = math.clamp((self._featureFade[feature] or 1) + delta / math.max(self._settings.FadeSpeed, 0.01), 0, 1)
    return self._featureFade[feature]
end

function ESPObject:_setFeatureAlpha(feature, alpha)
    if feature == "Box" then
        self:_setDrawingAlpha(self._drawings.box, alpha)
        self:_setDrawingAlpha(self._drawings.boxOutline, alpha)
        for _, line in ipairs(self._drawings.cornerOutlines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.cornerLines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.roundedOutlines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.roundedLines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.dashedOutlines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.dashedLines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.box3DOutlines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.box3DLines) do self:_setDrawingAlpha(line, alpha) end
    elseif feature == "Name" then
        self:_setDrawingAlpha(self._drawings.nameLabel, alpha)
    elseif feature == "Distance" then
        self:_setDrawingAlpha(self._drawings.distLabel, alpha)
    elseif feature == "Profile" then
        if self._profileGui then
            self._profileGui.Frame.BackgroundTransparency = math.clamp(1 - alpha, 0, 1)
            self._profileGui.Image.ImageTransparency = math.clamp(1 - alpha, 0, 1)
            self._profileGui.Stroke.Transparency = math.clamp(1 - alpha, 0, 1)
        end
    elseif feature == "Health" then
        self:_setDrawingAlpha(self._drawings.healthBarBgOutline, alpha)
        self:_setDrawingAlpha(self._drawings.healthBarBg, alpha)
        self:_setDrawingAlpha(self._drawings.healthBarFill, alpha)
    elseif feature == "Skeleton" then
        for _, line in ipairs(self._skeletonOutlineLines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._skeletonLines) do self:_setDrawingAlpha(line, alpha) end
    elseif feature == "Snapline" then
        self:_setDrawingAlpha(self._drawings.snaplineOutline, alpha)
        self:_setDrawingAlpha(self._drawings.snapline, alpha)
    elseif feature == "HeadDot" then
        self:_setDrawingAlpha(self._drawings.headDotOutline, alpha)
        self:_setDrawingAlpha(self._drawings.headDot, alpha)
    elseif feature == "LookDirection" then
        self:_setDrawingAlpha(self._drawings.lookDirectionOutline, alpha)
        self:_setDrawingAlpha(self._drawings.lookDirection, alpha)
        for _, line in ipairs(self._drawings.lookDirectionArrowOutlines) do self:_setDrawingAlpha(line, alpha) end
        for _, line in ipairs(self._drawings.lookDirectionArrows) do self:_setDrawingAlpha(line, alpha) end
    end
end

